import matplotlib.pyplot as plt

print(plt.style.available)


plt.style.use("seaborn-v0_8-deep")
# Data
labels = ["Sachin", "Sehwag", "Kohli", "Yuvraj"]
runs = [18000, 8000, 12000, 9500]
plt.title("Career Runs of Indian Batsmen")
colors = ['#ff9999','#66b3ff','#99ff99','#ffcc99']
explode = [0.3,0,0,0]
plt.pie(runs,labels=labels,colors=colors,
       wedgeprops={'edgecolor':'black','linewidth':2,'linestyle':'--'},explode=explode,
       shadow=True,startangle=140,autopct='%1.1f%%',)


# Too many categories
languages = ['Python', 'Java', 'C++', 'JavaScript', 'C#', 'Ruby', 'Go', 'Rust', 'Swift', 'PHP']
usage = [30, 20, 10, 10, 7, 5, 4, 3, 2, 1]

plt.pie(usage, labels=languages, autopct='%1.1f%%', startangle=90)
plt.title("Programming Language Usage (Crowded Example)")



plt.barh(languages,usage,color="skyblue")
plt.xlabel("Usage")
plt.ylabel("Language")
plt.title("Programming Language Usage (Crowded Example)")

# Add labels at end of each bar
for i in range(len(languages)):
    plt.text(usage[i] + 0.1, i, str(usage[i]), va='center')
plt.tight_layout()



